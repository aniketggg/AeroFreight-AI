# Copy to step3_riya/.env and fill in private values locally.
# Never commit step3_riya/.env.
#
# All three routing agents (AIR, SHIP, and Router) use Agentverse mailbox
# delivery. They do not require separate local port variables — run each
# process in its own terminal and keep it connected via the Inspector.

RIYA_AGENT_SEED=
AIR_AGENT_ADDRESS=
SHIP_AGENT_ADDRESS=

AIR_AGENT_SEED=
SHIP_AGENT_SEED=
