# Copy to step3_riya/.env and fill in private values locally.
# Never commit step3_riya/.env.
#
# All three routing agents use Agentverse mailbox delivery for messaging.
# Separate local ports below are for each agent's Agent Inspector only.
# Run AIR, SHIP, and Router in separate terminals and connect each via
# its Inspector URL on the configured port.

RIYA_AGENT_SEED=
AIR_AGENT_ADDRESS=
SHIP_AGENT_ADDRESS=

AIR_AGENT_SEED=
SHIP_AGENT_SEED=

AIR_AGENT_PORT=8011
SHIP_AGENT_PORT=8012
RIYA_AGENT_PORT=8013
